# Node pinned to 24.18.0 to match client/.nvmrc and the production Dockerfile.
FROM node:24.18.0-alpine

# Create app directory
RUN mkdir -p /usr/src/app
WORKDIR /usr/src/app

# node:alpine already ships node + npm; add git, then enable pnpm via corepack
# (version pinned by package.json "packageManager", matching the production Dockerfile)
RUN apk add --no-cache git && corepack enable

# Copy manifest, lockfile, and pnpm settings, then install
COPY package.json pnpm-lock.yaml .npmrc pnpm-workspace.yaml /usr/src/app/
RUN pnpm install --frozen-lockfile

ENV HOST 0.0.0.0

EXPOSE 4200
