{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Angular at localhost:4200",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:4200",
            "webRoot": "${workspaceFolder}/client"
        },
        {
            "name": "ng serve",
            "type": "chrome",
            "request": "launch",
            "preLaunchTask": "npm: start",
            "webRoot": "${workspaceFolder}/client",
            "url": "http://localhost:4200/"
        },
        {
            "name": "Debug Java Application",
            "type": "java",
            "request": "attach",
            "hostName": "localhost",
            "port": 5005,
            "projectName": "application-server",
            "comment": "Start with: ./gradlew :application-server:bootRunDevDebug"
        }
    ]
}
